{
  "slug": "repeater-basic",
  "form_name": "[TEST] Repeater Field",
  "description": "[TEST] Seeded form — repeater with sub-fields, per-row conditions, validation on sub-fields",
  "form_type": "standard",
  "config": {
    "form_name": "[TEST] Repeater Field",
    "form_type": "standard",
    "settings": { "store_submissions": true },
    "notifications": [],
    "actions": [
      { "action_id": "a1", "action_type": "save_submission", "enabled": true, "config": {} }
    ],
    "steps": [
      {
        "step_id": "step_1",
        "step_name": "Event Registration",
        "routing": [],
        "fields": [
          {
            "field_id": "event_name",
            "field_type": "text",
            "label": "Event Name",
            "placeholder": "Company Conference 2026",
            "required": true,
            "validation_rules": [
              { "rule": "min_length", "value": "3", "message": "" }
            ],
            "conditions": []
          },
          {
            "field_id": "event_date",
            "field_type": "date",
            "label": "Event Date",
            "required": true,
            "validation_rules": [
              { "rule": "date_after", "value": "today", "message": "Event date must be in the future." }
            ],
            "conditions": []
          },
          {
            "field_id": "attendees",
            "field_type": "repeater",
            "label": "Attendees",
            "required": false,
            "min_rows": 1,
            "max_rows": 10,
            "add_label": "Add Attendee",
            "remove_label": "Remove",
            "validation_rules": [],
            "conditions": [],
            "sub_fields": [
              {
                "field_id": "attendee_name",
                "field_type": "text",
                "label": "Name",
                "placeholder": "Full name",
                "required": true,
                "validation_rules": [
                  { "rule": "min_length", "value": "2", "message": "" }
                ],
                "conditions": []
              },
              {
                "field_id": "attendee_email",
                "field_type": "email",
                "label": "Email",
                "placeholder": "person@example.com",
                "required": true,
                "validation_rules": [],
                "conditions": []
              },
              {
                "field_id": "attendee_role",
                "field_type": "select",
                "label": "Role",
                "required": true,
                "options": [
                  { "value": "",         "label": "Select role" },
                  { "value": "attendee", "label": "Attendee" },
                  { "value": "speaker",  "label": "Speaker" },
                  { "value": "vip",      "label": "VIP Guest" },
                  { "value": "staff",    "label": "Staff" }
                ],
                "validation_rules": [],
                "conditions": []
              },
              {
                "field_id": "speaker_bio",
                "field_type": "textarea",
                "label": "Speaker Bio",
                "placeholder": "Brief biography for the event programme…",
                "required": false,
                "validation_rules": [
                  { "rule": "min_words", "value": "10",  "message": "Bio should be at least 10 words." },
                  { "rule": "max_words", "value": "100", "message": "Bio must be 100 words or fewer." }
                ],
                "conditions": [
                  {
                    "logic_group": "AND",
                    "source_field": "attendee_role",
                    "operator": "equals",
                    "compare_value": "speaker",
                    "action": "show",
                    "action_value": ""
                  },
                  {
                    "logic_group": "AND",
                    "source_field": "attendee_role",
                    "operator": "equals",
                    "compare_value": "speaker",
                    "action": "require",
                    "action_value": ""
                  }
                ]
              },
              {
                "field_id": "vip_requirements",
                "field_type": "text",
                "label": "VIP Requirements",
                "placeholder": "e.g. Dietary needs, accessibility…",
                "required": false,
                "validation_rules": [],
                "conditions": [
                  {
                    "logic_group": "AND",
                    "source_field": "attendee_role",
                    "operator": "equals",
                    "compare_value": "vip",
                    "action": "show",
                    "action_value": ""
                  }
                ]
              },
              {
                "field_id": "dietary",
                "field_type": "select",
                "label": "Dietary Requirements",
                "required": false,
                "options": [
                  { "value": "none",        "label": "No special requirements" },
                  { "value": "vegetarian",  "label": "Vegetarian" },
                  { "value": "vegan",       "label": "Vegan" },
                  { "value": "gluten_free", "label": "Gluten free" },
                  { "value": "halal",       "label": "Halal" },
                  { "value": "other",       "label": "Other (specify below)" }
                ],
                "validation_rules": [],
                "conditions": []
              },
              {
                "field_id": "dietary_other",
                "field_type": "text",
                "label": "Other Dietary Note",
                "placeholder": "Please specify",
                "required": false,
                "validation_rules": [],
                "conditions": [
                  {
                    "logic_group": "AND",
                    "source_field": "dietary",
                    "operator": "equals",
                    "compare_value": "other",
                    "action": "show",
                    "action_value": ""
                  },
                  {
                    "logic_group": "AND",
                    "source_field": "dietary",
                    "operator": "equals",
                    "compare_value": "other",
                    "action": "require",
                    "action_value": ""
                  }
                ]
              }
            ]
          },
          {
            "field_id": "organiser_notes",
            "field_type": "textarea",
            "label": "Organiser Notes",
            "placeholder": "Any internal notes…",
            "required": false,
            "validation_rules": [],
            "conditions": []
          }
        ]
      }
    ]
  }
}
